# Obsidian MCP Server Configuration
# Copy this file to .env and update with your settings.

# Path to your Obsidian vault (required)
# This is the root folder of your vault — the one containing your .obsidian/ directory.
# Example (macOS): /Users/yourname/Documents/My Obsidian Vault
# Example (Linux): /home/yourname/obsidian-vault
# Example (Windows/WSL): /mnt/c/Users/yourname/Documents/Obsidian Vault
VAULT_PATH="/path/to/your/Obsidian Vault"
